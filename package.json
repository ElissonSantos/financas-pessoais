{
  "name": "new-project",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24 <27"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @new-project/web --filter @new-project/api dev",
    "dev:web": "pnpm --filter @new-project/web dev",
    "dev:api": "pnpm --filter @new-project/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  }
}
